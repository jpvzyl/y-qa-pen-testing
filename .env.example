# Y-QA Pen Testing - Environment Configuration
# Copy this file to .env and fill in your values

# API base URL (default: /api/v1)
VITE_API_BASE_URL=/api/v1

# Backend server for development proxy
VITE_API_PROXY_TARGET=http://localhost:3000

# Demo mode: set to "true" to use mock data (standalone demo without backend)
# Leave unset or "false" for production with real y-qa API
VITE_DEMO_MODE=false
